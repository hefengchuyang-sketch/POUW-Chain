# POUW Chain environment variables
# Copy this file to .env and fill in real values
# Warning: .env must not be committed to version control!

# ===== Production mode =====
MAINCOIN_PRODUCTION=true

# ===== SSH deployment credentials =====
# Used by deployment and maintenance scripts under scripts/
SSH_PASSWORD=
# SSH key authentication is recommended over password

# ===== API admin key =====
# Used for RPC admin endpoint authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ===== Security hardening options =====
# Force API key auth even for local requests (recommended in production)
# Default: true (secure by default)
REQUIRE_LOCAL_AUTH=true

# Allow overriding authenticated user identity with X-Auth-User header.
# Keep false in production; only enable for local multi-role demo.
ALLOW_AUTH_USER_OVERRIDE=false

# Allow in-process execution fallback when Docker is unavailable.
# Keep false in production to avoid reduced isolation.
ALLOW_INPROCESS_FALLBACK=false

# ===== Node configuration =====
POUW_DATA_DIR=./data
POUW_CONFIG=./config.yaml
NODE_NAME=POUW-Node-1
