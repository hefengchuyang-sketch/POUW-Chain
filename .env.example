# POUW Chain 环境变量配置
# 复制此文件为 .env 并填入实际值
# 警告: .env 文件不应提交到版本控制！

# ===== 生产模式 =====
MAINCOIN_PRODUCTION=true

# ===== SSH 部署凭证 =====
# 用于 scripts/ 下的部署和运维脚本
SSH_PASSWORD=
# 建议使用 SSH 密钥认证替代密码

# ===== API 管理密钥 =====
# 用于 RPC 管理接口的认证
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ===== 安全加固选项 =====
# 强制本地请求也需要 API Key 认证（生产环境推荐启用）
# 默认: false（开发环境友好）
# 生产: true（防止容器内 SSRF 提权攻击）
REQUIRE_LOCAL_AUTH=false

# ===== 节点配置 =====
POUW_DATA_DIR=./data
POUW_CONFIG=./config.yaml
NODE_NAME=POUW-Node-1
