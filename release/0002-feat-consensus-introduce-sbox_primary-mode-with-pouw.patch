+            if has_pouw:
+                selected = ConsensusType.POUW
+                self._record_selected_consensus(selected)
+                return selected
+
+            self.log("⚠️ S-Box/POUW 均不可用，回退 PoW")
+            selected = ConsensusType.POW
+            self._record_selected_consensus(selected)
+            return selected
+
         # mixed 模式：按确定性比例混用
         if sbox_available and has_pouw:
             latest = self.get_latest_block()
