+            RPCPermission.PUBLIC,
+        )
+        self.register(
+            "account_getTransactions", self.svc._account_get_transactions,
+            "获取交易历史",
+            RPCPermission.USER,
+        )
+        self.register(
+            "account_getSubAddresses", self.svc._account_get_sub_addresses,
+            "获取子地址列表",
+            RPCPermission.USER,
+        )
+        self.register(
